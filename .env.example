# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://127.0.0.1:27017/nullscape

JWT_ACCESS_SECRET=change-me-min-32-chars
JWT_REFRESH_SECRET=change-me-different-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Production: comma-separated browser origins allowed to call the API (required for CORS)
# CORS_ORIGIN=https://admin.example.com,https://www.example.com

# Email (optional, for inquiries / mailer)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ADMIN_EMAIL=

# App URLs (optional; used by scripts / emails)
# ADMIN_URL=https://admin.example.com
